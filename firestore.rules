rules_version = '2';

// WeTravel Firestore 安全規則
// 部署方式：Firebase Console → Firestore Database → 規則 → 貼上本檔內容 → 發布
//
// 協作模型：行程以「知道連結（tripId）即可協作」的方式共享，
// 因此已登入（含匿名登入）者可讀寫 trips；其餘路徑一律拒絕。
service cloud.firestore {
  match /databases/{database}/documents {

    // 行程文件：需登入（App 使用匿名登入）
    // 刪除一律拒絕：App 採封存制（archived 旗標），不存在正當的刪除路徑；
    // 這條規則防止有人繞過 App 直接呼叫 deleteDoc 毀損資料。
    match /trips/{tripId} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }

    // 其他所有路徑：一律拒絕
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
